{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "indicator_card_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "indicator_name",
    "what_it_measures",
    "use_cases",
    "failure_modes",
    "best_regimes",
    "avoid_regimes",
    "source_ids",
    "risk_note"
  ],
  "properties": {
    "version": {
      "const": "indicator_card_v1"
    },
    "indicator_name": {
      "type": "string"
    },
    "what_it_measures": {
      "type": "string"
    },
    "use_cases": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "failure_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "best_regimes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "avoid_regimes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "risk_note": {
      "const": "educational_not_trade_instruction"
    }
  }
}
