{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "setup_playbook_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "pattern",
    "market_regime",
    "entry_checklist",
    "invalidation_rules",
    "avoid_if",
    "required_evidence",
    "source_ids",
    "risk_note"
  ],
  "properties": {
    "version": {
      "const": "setup_playbook_v1"
    },
    "pattern": {
      "type": "string"
    },
    "market_regime": {
      "type": "string"
    },
    "entry_checklist": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "invalidation_rules": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "avoid_if": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "required_evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "risk_note": {
      "const": "research_only_not_execution_advice"
    }
  }
}
