{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "wiki_term_pass_v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "term",
    "one_liner",
    "definition",
    "why_it_matters",
    "pitfalls",
    "related_terms",
    "source_ids",
    "risk_note"
  ],
  "properties": {
    "version": {
      "const": "wiki_term_pass_v1"
    },
    "term": {
      "type": "string"
    },
    "one_liner": {
      "type": "string"
    },
    "definition": {
      "type": "string"
    },
    "why_it_matters": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "formula_text": {
      "type": "string"
    },
    "pitfalls": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "related_terms": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 8
      }
    },
    "risk_note": {
      "const": "educational_not_trade_instruction"
    }
  }
}
